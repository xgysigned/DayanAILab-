LLM_API_BASE=https://your-model-api.example.com/v1
LLM_API_KEY=your_api_key
LLM_MODEL=your_chat_model

EMBEDDING_API_BASE=https://your-embedding-api.example.com/v1
EMBEDDING_API_KEY=your_api_key
EMBEDDING_MODEL=your_embedding_model

RERANK_API_BASE=https://your-rerank-api.example.com/v1
RERANK_API_KEY=your_api_key
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Set these to 1 if you want to run the demo without online services.
RAG_DEMO_OFFLINE_EMBEDDINGS=0
RAG_DEMO_OFFLINE_LLM=0

# Optional. Keep "rule" for offline demo, use "api" for BAAI/bge-reranker-v2-m3.
RAG_DEMO_RERANK_MODE=api
